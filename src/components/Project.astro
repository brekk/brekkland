---
import "@/components/Project.scss"
import Badge from "@/components/Badge.astro"
import blem from "#/utilities/blem"
const bem = blem("Project")
console.log("poprops", Astro.props)
const {
  title,
  description,
  repo,
  version,
  isPublished,
  hasBinary,
  meta,
  image,
  dependencies = [],
  related = [],
  tags = [],
} = Astro.props
---

<div class={bem("")}>
  <article class={bem("content")}>
    <header class={bem("header")}>
      <h1 class={bem("title")}>{title}</h1>
      <small class={bem("version")}>
        {version}
      </small>
      <div class={bem("details")}>
        <div class={bem("badges")}>
          <Badge m={[hasBinary ? "tool" : "library"]}>
            {hasBinary ? "Tool" : "Library"}
          </Badge>
        </div>
      </div>
      <p class={bem("description")}>
        {description}
      </p>
    </header>
  </article>
</div>
