---
import Row from "@/components/ProjectDetailRow.astro"
import "@/components/Project.scss"
import Tags from "@/components/Tags.astro"
import ArrowUp from "#/public/svg/arrow.svg"
import MagicDate from "@/components/Date.tsx"
import GithubLogo from "#/public/svg/github-black.svg"
import Badge from "@/components/Badge.astro"
import blem from "#/utilities/blem"
const bem = blem("Project")
const { rendered, data } = Astro.props
const {
  title,
  description,
  repo,
  version,
  isPublished,
  hasBinary,
  meta,
  image,
  dependencies = [],
  related = [],
  published,
  updated,
  tags = [],
} = data
const {
  metadata: { headings },
} = rendered
import { slug } from "#/utilities/string"
import Tag from "@/components/Tag.astro"
interface HeadingType {
  depth: number
  slug: string
  text: string
}
const domainRepo = "github.com"
---

<main class={bem("")} id="project">
  <div class={bem("wrapper")}>
    <section class={bem("section", "content")}>
      <header class={bem("header")}>
        <h1 class={bem("title")}>{title}</h1>

        <p class={bem("description")}>
          {description}
        </p>
      </header>
    </section>
    <section class={bem("section", "details")}>
      <strong class={bem("second-title")}>{title}</strong>

      <div class={bem("rows")}>
        <div class={bem("row", "badges")}>
          <Badge m={[hasBinary ? "tool" : "library"]}>
            {hasBinary ? "Tool" : "Library"}
          </Badge>
        </div>
        <Row class={bem("row", "source")}>
          <div slot="label" class={bem("label", "repo")}>Source</div>
          <a
            class={bem("repo-link")}
            href={"//" + domainRepo + "/" + repo}
            aria-label="Go to code repository"
          >
            <GithubLogo class={bem("icon", "github")} />
            <span class={bem("repo-text")}>{repo}</span>
          </a>
        </Row>
        <Row class={bem("row", "version")}>
          <div slot="label" class={bem("label", "version")}>Version</div>
          {version}
        </Row>
        <Row class={bem("row", "published")}>
          <div slot="label" class={bem("label", ["date", "published"])}>
            Published
          </div>
          <MagicDate isoString={published} />
        </Row>

        <Row class={bem("row", "updated")}>
          <div slot="label" class={bem("label", ["date", "updated"])}>
            Last Updated
          </div>
          <MagicDate isoString={updated} />
        </Row>
        <Row class={bem("row", "tags")}>
          <div slot="label" class={bem("label", "tags")}>Tags</div>
          <Tags tags={tags} />
        </Row>

        <Row class={bem("row", "dependencies")}>
          <div slot="label" class={bem("label", ["dependencies"])}>
            Dependencies
          </div>
          <ul class={bem("dependency-list")}>
            {
              dependencies.map((d: string) => (
                <li class={bem("dependency")}>
                  <a
                    class={bem("dependency-link")}
                    href={`${import.meta.env.BASE_URL}/software/${d.toLowerCase()}`}
                  >
                    {d}
                  </a>
                </li>
              ))
            }
          </ul>
        </Row>
        <Row class={bem("row", "explorer")}>
          <div slot="label" class={bem("label", "headings")}>Jump to</div>

          <ol class={bem("headings-list")}>
            {
              headings.map((h: HeadingType) => {
                const sizeCl = `size-${h.depth}`
                return (
                  <li class={bem("heading-list-item", [sizeCl])}>
                    <a
                      class={bem("heading-link", [sizeCl])}
                      href={`#${h.slug}`}
                    >
                      {h.text}
                    </a>
                  </li>
                )
              })
            }
          </ol>
        </Row>
        <a
          class={bem("scroll-to-top")}
          href="#body"
          aria-label="Scroll document to top"
        >
          <ArrowUp class={bem("svg", "arrow")} />
        </a>
      </div>
    </section>
    <section class={bem("section", "usage")}>
      <div class={bem("slot")}>
        <slot />
      </div>
    </section>
  </div>
</main>

<script>
  const project = document.getElementById("project")
  const nav = document.getElementById("nav")
  const slots = document.getElementsByClassName("Project__slot")
  const full = window.outerHeight
  if (project && slots.length > 0) {
    const navHeight = nav?.getBoundingClientRect()?.height ?? 400
    const slot = slots[0]
    const boxHeight = slot.getBoundingClientRect()?.height
    const minHeight = full >= boxHeight ? full : boxHeight
    // @ts-ignore
    project.style.minHeight = minHeight + navHeight + "px"
  }
</script>
