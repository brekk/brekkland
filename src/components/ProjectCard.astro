---
import Brekkland from "@/layouts/Brekkland.astro"
import Tags from "@/components/Tags.astro"
import "@/pages/projects/index.scss"
import { getCollection } from "astro:content"
const projects = await getCollection("projects")
import blem from "#/utilities/blem"
const bem = blem("Projects")
import MagicDate from "@/components/Date"
const {
  id,
  data: { tags = [], updated, title, hasBinary, hypothetical },
} = Astro.props

const link = `/projects/${id}`
const status = [
  hasBinary ? "tool" : "library",
  hypothetical ? "unpublished" : "published",
]
---

<li class={bem("project-card", status)}>
  <div class={bem("info", status)}>
    <a href={link} class={bem("project-title")}>{title ?? id}</a>
  </div>
  <div class={bem("details")}>
    <!--<Tags tags={tags} />-->
    {
      updated ? (
        <span class={bem("date", "last-updated")}>
          <MagicDate isoString={updated} />
        </span>
      ) : null
    }
  </div>
</li>
