---
import { type CollectionEntry, getCollection, render } from "astro:content"
import Brekkland from "@/layouts/Brekkland.astro"
import Project from "@/components/Project.astro"
import DesignConstants from "#/design/constants"

interface Props {
  project?: CollectionEntry<"projects">
}
export async function getStaticPaths() {
  const projects = await getCollection("projects")
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }))
}
const { project } = Astro.props
console.log("PROJECT", project)
if (!project) {
  return Astro.redirect(DesignConstants.path.SOFTWARE, 404)
}
const { Content } = await render(project)
---

<Brekkland
  breadcrumbs={[{ name: "software", path: DesignConstants.path.SOFTWARE }]}
>
  <Project {...project}>
    <Content />
  </Project>
</Brekkland>
